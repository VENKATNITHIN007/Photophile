# Photophile Frontend Environment Variables
# Copy this file to .env.local and fill in your actual values

# API Configuration
# The base URL for the backend API
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Note: This is the only environment variable required for the frontend.
# All authentication is handled via HTTP-only cookies set by the backend.
# Do not add any secret keys or sensitive information here.
